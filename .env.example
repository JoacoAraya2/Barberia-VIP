# ID de tu calendario de Google (usualmente es tu email o un ID largo)
GOOGLE_CALENDAR_ID=primary

# Ruta a tus credenciales de Google (descargadas de Google Cloud)
GOOGLE_CREDENTIALS_FILE=credentials.json

# URL de tu instancia de Evolution API (ej. http://localhost:8080)
EVOLUTION_API_URL=http://localhost:8080

# Tu API Key de Evolution API (la que definiste al instalar Docker)
EVOLUTION_API_KEY=tu_clave_api_aqui

# Nombre de la instancia en Evolution API (ej. maccielbot)
EVOLUTION_INSTANCE_NAME=maccielbot

# URL del modelo de IA (Ollama local o endpoint externo)
# Si usas Ollama local: http://host.docker.internal:11434
# Si usas Gemini u otro, pon la URL correspondiente
AI_MODEL_URL=http://localhost:11434/api/generate
AI_MODEL_NAME=qwen2.5:7b

# Zona horaria (ej. America/Mexico_City, America/Bogota, Europe/Madrid)
TIMEZONE=America/Mexico_City